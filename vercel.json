{
  "buildCommand": "pnpm typecheck",
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/webhook", "destination": "/api/webhook" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}
