{
  "name": "guluzada",
  "version": "0.1.0",
  "description": "Telegram-first AI assistant for Azerbaijanis",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --noEmit && tsc",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:types": "supabase gen types typescript --linked > src/db/types.ts",
    "eval": "tsx scripts/eval.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.49.4",
    "grammy": "^1.34.0",
    "openai": "^4.97.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/node": "^5.7.13",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "packageManager": "pnpm@10.33.0"
}
